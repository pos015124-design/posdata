# Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URL (required when the SPA and API use different origins)
# For same-origin hosting: leave empty
# For separate frontend + API: set to your API base URL and rebuild (e.g. npm run build)
# Example: VITE_API_URL=https://your-api.onrender.com
VITE_API_URL=

# Production checklist:
# - Set VITE_API_URL before building the client if the shop domain is not the API domain
# - On the API, consider ALLOWED_ORIGINS (see repo root .env.example)
# - Run: npm run smoke:public -- https://your-api-host
