{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/**"]
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/dist/assets/$1"
    },
    {
      "src": "/login",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/register",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/dashboard(.*)",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/pos(.*)",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/inventory(.*)",
      "dest": "/client/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
