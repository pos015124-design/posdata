{
  "name": "dukani-system",
  "version": "1.0.0",
  "private": true,
  "main": "server/server.js",
  "scripts": {
    "build": "cd client && npm install && npm run build",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && npm run dev",
    "client:dev": "cd client && npm run dev",
    "start": "cd server && node server.js",
    "postinstall": "cd server && npm install",
    "heroku-postbuild": "cd server && npm install && cd ../client && npm install && npm run build && echo 'Client build completed'",
    "create-admin": "cd server && node createAdmin.js",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "smoke:public": "node scripts/smoke-public-api.mjs"
  },
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "cacheDirectories": [
    "client/node_modules",
    "server/node_modules"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "axios": "^1.7.7",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^5.1.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.9",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.9.6",
    "mongoose-paginate-v2": "^1.8.5",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.12",
    "openai": "^4.63.0",
    "pdfkit": "^0.18.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react-chartjs-2": "^5.3.1",
    "redis": "^4.7.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
