# Backend (copy to server/.env or set in hosting dashboard)

# Browser origins (scheme + host + port, no path). Separate with COMMAS — not periods.
# Bad:  https://api.example.com.https://shop.example.com
# Good: https://api.example.com,https://shop.example.com
#
# Easiest on Render: FRONTEND_URL=https://e-shop.bhabygroup.co.tz
# Or merge: ALLOWED_ORIGINS=https://app.vercel.app,https://e-shop.bhabygroup.co.tz
# Permissive: leave unset or ALLOWED_ORIGINS=*
# FRONTEND_URL=https://e-shop.bhabygroup.co.tz

# MongoDB and other secrets — see server documentation

# Cloudinary — persistent image storage (required on Render, optional in dev)
# Sign up free at https://cloudinary.com, then copy from Dashboard > API Keys
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
