# Backend (copy to server/.env or set in hosting dashboard)

# Browser origins allowed when using strict CORS (scheme + host + port, no path). Match the SPA exactly.
# Easiest on Render: set one of these (they are merged):
#   FRONTEND_URL=https://e-shop.bhabygroup.co.tz
#   or CLIENT_URL / SHOP_URL (same value)
#   or ALLOWED_ORIGINS=http://localhost:5173,https://e-shop.bhabygroup.co.tz
# Permissive API (reflect any Origin): leave all unset, or set ALLOWED_ORIGINS=*
# ALLOWED_ORIGINS=https://e-shop.bhabygroup.co.tz
# FRONTEND_URL=https://e-shop.bhabygroup.co.tz

# MongoDB and other secrets — see server documentation
